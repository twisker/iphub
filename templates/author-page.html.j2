<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ author }} — {{ t.author_page_title }} — IpHub</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6; color: #24292f; background: #fff; max-width: 800px; margin: 0 auto; padding: 0 1rem 3rem;
    }
    .lang-bar {
      background: #f6f8fa; border-bottom: 1px solid #d0d7de; padding: 0.4rem 1rem;
      margin: 0 -1rem 1.5rem; font-size: 0.85rem; text-align: right;
    }
    .lang-bar a { color: #0969da; text-decoration: none; margin-left: 0.8rem; }
    .lang-bar a:hover { text-decoration: underline; }
    .lang-bar .active { font-weight: 600; color: #24292f; text-decoration: none; cursor: default; }
    h1 { font-size: 2rem; margin: 1rem 0 0.5rem; }
    h2 { font-size: 1.4rem; margin: 2rem 0 0.8rem; border-bottom: 1px solid #d0d7de; padding-bottom: 0.3rem; }
    h3 { font-size: 1.1rem; margin: 1.2rem 0 0.5rem; }
    table { width: 100%; border-collapse: collapse; margin: 0.8rem 0; }
    th, td { text-align: left; padding: 0.5rem 0.8rem; border: 1px solid #d0d7de; }
    th { background: #f6f8fa; font-weight: 600; }
    .desc { color: #57606a; font-size: 1.05rem; margin-bottom: 1rem; }
    hr { border: none; border-top: 1px solid #d0d7de; margin: 2rem 0; }
    .footer { color: #8b949e; font-size: 0.85rem; font-style: italic; }
    a { color: #0969da; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .stats {
      display: flex; gap: 2rem; margin: 1rem 0 1.5rem; flex-wrap: wrap;
    }
    .stat-box {
      background: #f6f8fa; border: 1px solid #d0d7de; border-radius: 6px;
      padding: 0.8rem 1.2rem; text-align: center; min-width: 120px;
    }
    .stat-box .number { font-size: 1.8rem; font-weight: 700; color: #0550ae; }
    .stat-box .label { font-size: 0.85rem; color: #57606a; }
    .back-link { margin-bottom: 1rem; font-size: 0.9rem; }
  </style>
</head>
<body>

<div class="lang-bar">
  {% if lang == "en" %}
  <a href="../zh-cn/">zh-cn</a>
  <span class="active">en</span>
  {% elif lang == "zh-cn" %}
  <a href="../en/">en</a>
  <span class="active">zh-cn</span>
  {% endif %}
</div>

<p class="back-link"><a href="/">&larr; IpHub</a></p>

<h1>{{ author }}</h1>
<p class="desc">{{ t.author_page_title }}</p>

<div class="stats">
  <div class="stat-box">
    <div class="number">{{ skills | length }}</div>
    <div class="label">{{ t.published_skills }}</div>
  </div>
  <div class="stat-box">
    <div class="number">{{ packages | length }}</div>
    <div class="label">{{ t.published_packages }}</div>
  </div>
  <div class="stat-box">
    <div class="number">{{ total_installs }}</div>
    <div class="label">{{ t.total_installs }}</div>
  </div>
</div>

<hr>

{# ── Skills ── #}
{% if skills %}
<h2>{{ t.published_skills }} ({{ skills | length }})</h2>
<table>
  <thead><tr><th>{{ t.skill }}</th><th>{{ t.description }}</th><th>{{ t.installs }}</th></tr></thead>
  <tbody>
    {% for s in skills %}
    <tr>
      <td><a href="/{{ author }}/{{ s.name }}/">{{ s.name }}</a></td>
      <td>{{ s.description | default('') }}</td>
      <td>{{ s.installs | default(0) }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{# ── Packages ── #}
{% if packages %}
<h2>{{ t.published_packages }} ({{ packages | length }})</h2>
<table>
  <thead><tr><th>{{ t.skill }}</th><th>{{ t.description }}</th><th>{{ t.version_history }}</th><th>{{ t.installs }}</th></tr></thead>
  <tbody>
    {% for p in packages %}
    <tr>
      <td><a href="/{{ author }}/{{ p.name }}/">{{ p.name }}</a></td>
      <td>{{ p.description | default('') }}</td>
      <td>{{ p.latest | default('') }}</td>
      <td>{{ p.installs | default(0) }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<hr>
<p class="footer">{{ t.auto_generated }}</p>

</body>
</html>
